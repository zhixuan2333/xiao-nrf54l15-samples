{
  "name": "XIAO nRF54L15 samples (NCS v3.3.0)",

  // Prebuilt nRF Connect SDK image (NCS source baked in). Built/published by
  // https://github.com/zhixuan2333/ncs-container
  "image": "ghcr.io/zhixuan2333/ncs-container:v3.3.0",

  "remoteUser": "root",
  "workspaceFolder": "/workspaces/xiao-nrf54l15-samples",

  // sshd is required for `gh codespace ssh -R` (the reverse tunnel used by
  // scripts/host-bridge.sh to reach your local OpenOCD/serial bridge).
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {}
  },

  "containerEnv": {
    "NCS_VERSION": "v3.3.0",
    "ZEPHYR_BASE": "/opt/ncs/v3.3.0/zephyr",
    "NCS_WORKSPACE": "/opt/ncs/v3.3.0",
    "BOARD": "xiao_nrf54l15/nrf54l15/cpuapp"
  },

  // NOTE: do NOT add forwardPorts for 3333/4444/4555. Those ports are provided
  // by the SSH reverse tunnel (scripts/host-bridge.sh); VS Code auto-forwarding
  // the same ports fights the tunnel and causes connection storms.

  "customizations": {
    "vscode": {
      "extensions": [
        "nordic-semiconductor.nrf-connect-extension-pack",
        "marus25.cortex-debug",
        "ms-vscode.cpptools"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
