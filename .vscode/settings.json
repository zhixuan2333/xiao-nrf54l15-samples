{
  // Rebind the nRF Connect "Flash" action (toolbar button / shortcut) to run the
  // remote-OpenOCD flash task instead of the default nrfutil/J-Link runner.
  //
  // taskBindings is an OBJECT keyed by action (flash / build / pristineBuild /
  // eraseAndFlash); each maps to an array of { taskName, buildConfigs? }.
  // Omitting buildConfigs applies the binding to every build configuration.
  "nrf-connect.taskBindings": {
    "flash": [
      { "taskName": "Flash (remote OpenOCD)" }
    ]
  }
}
